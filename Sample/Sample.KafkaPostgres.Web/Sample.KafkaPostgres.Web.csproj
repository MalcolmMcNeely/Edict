<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Sample.KafkaPostgres.Web</RootNamespace>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Orleans.Client" Version="10.1.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../Sample.ServiceDefaults/Sample.ServiceDefaults.csproj" />
        <!--
          Same substrate-agnostic Razor class library as Sample.Azure.Web. This host
          differs only in Program.cs — projection-row repositories are bound
          to PostgresTableRepository against the AppHost-injected appdb
          connection string instead of AzureTableRepository against Tables.
        -->
        <ProjectReference Include="../Sample.Web.Components/Sample.Web.Components.csproj" />
        <ProjectReference Include="../Sample.Contracts/Sample.Contracts.csproj" />
        <ProjectReference Include="../Sample.Domain/Sample.Domain.csproj" />
        <ProjectReference Include="../../Edict/Edict.Postgres/Edict.Postgres.csproj" />
        <ProjectReference Include="../../Edict/Edict.Core/Edict.Core.csproj" />
    </ItemGroup>

</Project>
