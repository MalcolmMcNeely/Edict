<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Sample.Web</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Orleans.Client" Version="10.1.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../Sample.ServiceDefaults/Sample.ServiceDefaults.csproj" />
        <!--
          Reference Sample.Domain for the generated grain interfaces (IOrderGrain
          et al.) and the [assembly: EdictRoutes] annotation that AddEdict() in
          Edict.Core picks up at startup. The substrate-specific Sample.Silo
          host is irrelevant to the web tier; the contracts + domain pair is
          what the Blazor app actually binds to.
        -->
        <ProjectReference Include="../Sample.Contracts/Sample.Contracts.csproj" />
        <ProjectReference Include="../Sample.Domain/Sample.Domain.csproj" />
        <ProjectReference Include="../../Edict/Edict.Azure/Edict.Azure.csproj" />
        <ProjectReference Include="../../Edict/Edict.Core/Edict.Core.csproj" />
    </ItemGroup>

</Project>
