@page "/"
@inject IEdictDeadLetterRepository DeadLetterRepository
@implements IDisposable

<PageTitle>Edict Sample — Home</PageTitle>

<h1>Edict sample app</h1>

<p>
    Edict is a CQRS, event-driven framework built on Microsoft Orleans. This
    Blazor app is the canonical consumer reference: every page demonstrates one
    of Edict's primitives, every Command fires from an explicit button click,
    and every live read-model view refreshes from the framework's projections.
</p>

<p>
    Use the left navigation to explore each capability. Pages other than Home
    will be wired up in subsequent slices.
</p>

<h2>Live counters</h2>

<div class="counter-grid">
    <div class="counter-card">
        <div class="label">Orders projected</div>
        <div class="value">@OrdersCounterDisplay</div>
        <div class="note">@OrdersCounterNote</div>
    </div>
    <div class="counter-card">
        <div class="label">In-flight fulfillments</div>
        <div class="value">0</div>
        <div class="note">Wired in a later slice (Fulfillment feature).</div>
    </div>
    <div class="counter-card">
        <div class="label">Dead-letter rows</div>
        <div class="value">@DeadLetterCount</div>
        <div class="note">Fleet-wide <code>IEdictDeadLetterRepository</code>.</div>
    </div>
</div>

<h2>What each nav entry demonstrates</h2>

<ul class="nav-descriptor">
    <li><strong>Home</strong> Prose intro and the three live counters above.</li>
    <li><strong>Orders</strong> Place / Add line / Submit / Cancel commands. Drives the OrderPaymentSaga and writes the Orders projection.</li>
    <li><strong>Fulfillment</strong> Second saga (OrderFulfillmentSaga) plus a grain-timer-driven aggregate ticking line items to Fulfilled.</li>
    <li><strong>Dead Letter</strong> Buttons that trigger permanent failures (handler throw, saga-command rejection, validator rejection) so dead-letter rows appear.</li>
    <li><strong>Claim Check</strong> Oversize-payload escape hatch. Observed via the Aspire telemetry dashboard rather than the data plane.</li>
    <li><strong>Idempotency</strong> Explanatory page — the dedup ring stamps EventIds the consumer cannot forge.</li>
</ul>

@code {
    PeriodicTimer? _timer;
    CancellationTokenSource? _cts;

    int DeadLetterCount { get; set; }
    string OrdersCounterDisplay { get; set; } = "—";
    string OrdersCounterNote { get; set; } = "Per-order partitions; fleet-wide enumeration arrives in a later slice.";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync(_cts.Token);
    }

    async Task PollAsync(CancellationToken ct)
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync(ct))
            {
                await RefreshAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    async Task RefreshAsync()
    {
        try
        {
            var entries = await DeadLetterRepository.ListAllAsync();
            DeadLetterCount = entries.Count;
        }
        catch
        {
            DeadLetterCount = 0;
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _timer?.Dispose();
        _cts?.Dispose();
    }
}
