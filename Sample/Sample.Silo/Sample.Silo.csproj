<Project Sdk="Microsoft.NET.Sdk.Worker">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Sample.Silo</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Orleans.Server" Version="10.1.0" />
        <PackageReference Include="Microsoft.Orleans.Streaming.AzureStorage" Version="10.1.0" />
        <PackageReference Include="Microsoft.Orleans.Persistence.AzureStorage" Version="10.1.0" />
        <PackageReference Include="Microsoft.Orleans.Reminders.AzureStorage" Version="10.1.0" />
        <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
        <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../../Edict/Edict.Azure/Edict.Azure.csproj" />
        <ProjectReference Include="../../Edict/Edict.Core/Edict.Core.csproj" />
        <!--
          Generator runs over this assembly — emits IOrderGrain, Dispatch, and AddEdict().
          ReferenceOutputAssembly=false: we only need the generator to run, not to link it.
        -->
        <ProjectReference Include="../../Edict/Edict.Generators/Edict.Generators.csproj"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false" />
        <ProjectReference Include="../../Edict/Edict.Analyzers/Edict.Analyzers.csproj"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false" />
    </ItemGroup>

</Project>
