<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />

        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
        <PackageReference Include="Verify.Xunit" Version="31.12.5" />
        <PackageReference Include="xunit" Version="2.9.3" />
        <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
        <!-- For the EDICT018 packaging integration test below: load the analyzer
             in-process and run it against a consumer-shaped source. -->
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    </ItemGroup>

    <ItemGroup>
        <!-- The consumer assembly under test: its grains + generated [assembly: EdictRoutes].
             Lives in Sample.Domain since #137; Sample.Azure.Silo is the Azure host. -->
        <ProjectReference Include="../Sample.Domain/Sample.Domain.csproj" />
        <!-- The shipped in-memory Test Framework. -->
        <ProjectReference Include="../../Edict/Edict.Testing/Edict.Testing.csproj" />
        <!-- For OrleansReadyHealthCheck + OrleansReadyGate; the sample-side cross-cutting
             helpers live in ServiceDefaults so both silos and Web can wire them. -->
        <ProjectReference Include="../Sample.ServiceDefaults/Sample.ServiceDefaults.csproj" />
        <!-- For the analyzer-packaging integration test (HandleMustBeHandleAsyncAnalyzerPackagingTests).
             ReferenceOutputAssembly=true so the test can directly instantiate the
             analyzer and assert it fires on consumer-shaped source. -->
        <ProjectReference Include="../../Edict/Edict.Analyzers/Edict.Analyzers.csproj" ReferenceOutputAssembly="true" />
    </ItemGroup>

</Project>
