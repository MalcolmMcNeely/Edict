<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsAspireHost>true</IsAspireHost>
        <UserSecretsId>sample-apphost-edict</UserSecretsId>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <Sdk Name="Aspire.AppHost.Sdk" Version="13.3.1" />

    <ItemGroup>
        <PackageReference Include="Aspire.Hosting.AppHost" Version="13.3.5" />
        <PackageReference Include="Aspire.Hosting.Azure.Storage" Version="13.3.5" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../Sample.Azure.Silo/Sample.Azure.Silo.csproj" />
        <ProjectReference Include="../Sample.Azure.Web/Sample.Azure.Web.csproj" />
    </ItemGroup>

</Project>
