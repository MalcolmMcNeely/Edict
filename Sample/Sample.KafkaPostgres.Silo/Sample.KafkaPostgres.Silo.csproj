<Project Sdk="Microsoft.NET.Sdk.Worker">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Sample.KafkaPostgres.Silo</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Orleans.Server" Version="10.1.0" />
        <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
        <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    </ItemGroup>

    <ItemGroup>
        <!--
          Same Sample.Domain assembly as the Azure-substrate Sample.Silo —
          the handlers/sagas/projection builders are substrate-agnostic
          (issue #137 extraction), and this host swaps only the streams +
          persistence providers via the Edict.Kafka + Edict.Postgres
          references below. Program.cs reads side-by-side with
          Sample.Silo/Program.cs as the substrate-comparison page.
        -->
        <ProjectReference Include="../Sample.Domain/Sample.Domain.csproj" />
        <ProjectReference Include="../../Edict/Edict.Kafka/Edict.Kafka.csproj" />
        <ProjectReference Include="../../Edict/Edict.Postgres/Edict.Postgres.csproj" />
    </ItemGroup>

</Project>
