<Project Sdk="Microsoft.NET.Sdk.Razor">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Sample.Web.Components</RootNamespace>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <SupportedPlatform Include="browser" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.App.Internal.Assets" Version="10.0.8" />
        <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.8" />
        <!-- Hub.razor injects IEdictSender; the Aspire AppHost's silo binds it.
             The RCL just needs the contract types to compile. -->
        <PackageReference Include="Microsoft.AspNetCore.Components" Version="10.0.8" />
    </ItemGroup>

    <ItemGroup>
        <!--
          The RCL binds to consumer contract types (commands, projection rows,
          dead-letter entries) and the framework's IEdictSender / repository
          interfaces. It is host-agnostic: any sample (Azure today, Kafka/Postgres
          tomorrow) can MapRazorComponents<App>() against this assembly.
        -->
        <ProjectReference Include="../Sample.Contracts/Sample.Contracts.csproj" />
        <ProjectReference Include="../Sample.Domain/Sample.Domain.csproj" />
        <ProjectReference Include="../../Edict/Edict.Core/Edict.Core.csproj" />
    </ItemGroup>

</Project>
