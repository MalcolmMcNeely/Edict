<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsAspireHost>true</IsAspireHost>
        <UserSecretsId>sample-apphost-edict</UserSecretsId>
    </PropertyGroup>

    <Sdk Name="Aspire.AppHost.Sdk" Version="13.3.1" />

    <ItemGroup>
        <PackageReference Include="Aspire.Hosting.AppHost" Version="13.3.1" />
        <PackageReference Include="Aspire.Hosting.Azure.Storage" Version="13.3.1" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../Sample.Silo/Sample.Silo.csproj" />
        <ProjectReference Include="../Sample.Web/Sample.Web.csproj" />
    </ItemGroup>

</Project>
