<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>true</IsPackable>
        <PackageId>Edict.Azure.Streaming</PackageId>
        <Description>Azure Queue Storage stream provider and blob-based claim-check store for the Edict CQRS framework. Pair with any Edict persistence package.</Description>
        <PackageTags>edict;cqrs;orleans;azure;queues;streaming</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Edict.Azure.Tests" />
        <InternalsVisibleTo Include="Edict.Kafka.Tests" />
        <InternalsVisibleTo Include="Edict.Substrate.Azurite" />
        <InternalsVisibleTo Include="Edict.Substrate.KafkaPostgres" />
        <InternalsVisibleTo Include="Edict.Testing" />
        <InternalsVisibleTo Include="Edict.Tests.Conformance" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Azure.Storage.Blobs" Version="12.28.0" />
        <PackageReference Include="Azure.Storage.Queues" Version="12.26.0" />
        <PackageReference Include="Microsoft.Orleans.Streaming.AzureStorage" Version="10.1.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Edict.Core\Edict.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>
